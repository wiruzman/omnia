{
  "include_paths": [
    "/Volumes"
  ],
  "exclude_globs": [
    ".git",
    "node_modules",
    "Library/Caches",
    ".Trash",
    "Trash"
  ],
  "index_db_path": "index.sqlite",
  "daemon_dir": "daemon",
  "daemon_log_file": "daemon.log",
  "daemon_log_level": "info",
  "daemon_log_max_bytes": 10485760,
  "daemon_log_backups": 5,
  "sort_column": "name",
  "sort_direction": "ASC",
  "max_results": 5000,
  "debounce_ms": 120,
  "scan_batch_size": 1000,
  "scan_throttle_every": 250,
  "scan_throttle_ms": 5
}
